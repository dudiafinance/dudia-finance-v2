# Database (Neon)
DATABASE_URL="postgresql://..."
DIRECT_DATABASE_URL="postgresql://..."

# Auth (Clerk)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...

# AI (OpenRouter) - DESCONTINUADO
OPENROUTER_API_KEY=sk-or-v1-...

# Encryption (AES-256-CBC)
# Required for production. Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# Cron Security
CRON_SECRET=your-secure-cron-secret

# Testing / Debug
AIOX_DEBUG_TOKEN=debug-token-default

# Monitoring (Sentry)
NEXT_PUBLIC_SENTRY_DSN=https://<your-sentry-dsn>@o<org-id>.ingest.us.sentry.io/<project-id>
SENTRY_AUTH_TOKEN=snt_...
